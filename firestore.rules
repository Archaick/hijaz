rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isHijazAdmin() {
      return request.auth != null
        && request.auth.token.email == "info@markazalhijaz.org";
    }

    // Dynamic Redirects:
    // - Public can read (for website redirect resolution)
    // - Only Hijaz admin account can write
    match /redirects/{docId} {
      allow read: if true;
      allow write: if isHijazAdmin();
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
