{
  "hosting": {
    "predeploy": [
      "node scripts/sync-redirects.mjs"
    ],
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "redirects": [
      {
        "source": "/",
        "destination": "/id/",
        "type": 301
      },
      {
        "source": "/qurbanalhijaz",
        "destination": "https://docs.google.com/forms/d/e/1FAIpQLScZw3c8y8-pbBPHFVgieqjfDQneuWlWhOt14MWG8cH3pZQddQ/viewform",
        "type": 302
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}