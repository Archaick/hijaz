{
  "hosting": {
    "predeploy": [
      "node scripts/sync-redirects.mjs"
    ],
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/id/",
        "type": 301
      },
      {
        "source": "/qurbanalhijaz",
        "destination": "https://docs.google.com/forms/d/e/1FAIpQLScZw3c8y8-pbBPHFVgieqjfDQneuWlWhOt14MWG8cH3pZQddQ/viewform",
        "type": 302
      }
    ]
  }
}
